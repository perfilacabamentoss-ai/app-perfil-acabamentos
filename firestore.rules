rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: ['admin', 'client', 'pro'])
    //
    // Collection: projects
    // Document ID: projectId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - workName: string (required)
    //   - type: string (required, enum: ['DWG', 'PDF'])
    //   - uploadDate: string (required)
    //   - uid: string (required)
    //
    // Collection: works
    // Document ID: workId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - uid: string (required)
    //
    // Collection: materials
    // Document ID: materialId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - uid: string (required)
    //
    // Collection: marketplace_professionals
    // Document ID: proId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //
    // Collection: marketplace_clients
    // Document ID: clientId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //
    // Collection: marketplace_requests
    // Document ID: requestId
    // Fields:
    //   - id: string (required)
    //   - clientId: string (required)
    //   - serviceType: string (required)
    //   - status: string (required)
    //
    // Collection: marketplace_messages
    // Document ID: messageId
    // Fields:
    //   - id: string (required)
    //   - senderId: string (required)
    //   - receiverId: string (required)
    //   - timestamp: string (required)
    //
    // Collection: marketplace_reviews
    // Document ID: reviewId
    // Fields:
    //   - id: string (required)
    //   - proId: string (required)
    //   - clientId: string (required)
    //   - rating: number (required)
    //
    // Collection: marketplace_feedbacks
    // Document ID: feedbackId
    // Fields:
    //   - id: string (required)
    //   - type: string (required)
    //   - text: string (required)
    //   - date: string (required)
    //
    // Collection: marketplace_specialties
    // Document ID: specialtyId
    // Fields:
    //   - name: string (required)
    //
    // Collection: clients
    // Document ID: clientId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - status: string (required)
    //
    // Collection: collaborators
    // Document ID: collaboratorId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - role: string (required)
    //   - status: string (required)
    //
    // Collection: suppliers
    // Document ID: supplierId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - category: string (required)
    //
    // Collection: contractors
    // Document ID: contractorId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - service: string (required)
    //   - status: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "perfilacabamentoss@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /works/{workId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /collaborators/{collaboratorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /contractors/{contractorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Marketplace Collections - Allowed for all users to support public browsing
    match /marketplace_professionals/{proId} {
      allow read: if true;
      allow write: if true; // Ideally restricted, but app uses custom login
    }

    match /marketplace_clients/{clientId} {
      allow read: if true;
      allow write: if true;
    }

    match /marketplace_requests/{requestId} {
      allow read: if true;
      allow write: if true;
    }

    match /marketplace_messages/{messageId} {
      allow read: if true;
      allow write: if true;
    }

    match /marketplace_reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    match /marketplace_feedbacks/{feedbackId} {
      allow read: if true;
      allow write: if true;
    }

    match /marketplace_specialties/{specialtyId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
