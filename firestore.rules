rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: ['admin', 'client', 'pro'])
    //
    // Collection: projects
    // Document ID: projectId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - workName: string (required)
    //   - type: string (required, enum: ['DWG', 'PDF'])
    //   - uploadDate: string (required)
    //   - size: string (optional)
    //   - author: string (optional)
    //   - version: string (optional)
    //   - uid: string (required)
    //
    // Collection: works
    // Document ID: workId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - owner: string (optional)
    //   - address: string (optional)
    //   - status: string (optional)
    //   - uid: string (required)
    //
    // Collection: materials
    // Document ID: materialId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - quantity: number (optional)
    //   - unit: string (optional)
    //   - workId: string (optional)
    //   - workName: string (optional)
    //   - lastRestock: string (optional)
    //   - uid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "perfilacabamentoss@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'client', 'pro']);
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'workName', 'type', 'uploadDate', 'uid']) &&
             data.id is string &&
             data.name is string &&
             data.workName is string &&
             data.type in ['DWG', 'PDF'] &&
             data.uploadDate is string &&
             data.uid is string;
    }

    function isValidWork(data) {
      return data.keys().hasAll(['id', 'name', 'uid']) &&
             data.id is string &&
             data.name is string &&
             data.uid is string;
    }

    function isValidMaterial(data) {
      return data.keys().hasAll(['id', 'name', 'uid']) &&
             data.id is string &&
             data.name is string &&
             data.uid is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(request.resource.data) && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidProject(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /works/{workId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidWork(request.resource.data) && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidWork(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMaterial(request.resource.data) && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidMaterial(request.resource.data) && (isDocOwner() || isAdmin());
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }
  }
}
